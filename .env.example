# Server configuration
PORT=3000
NODE_ENV=development

# AI Provider configurations
# Supported providers: mock, openai, gemini, openrouter
AI_PROVIDER=mock

# AI API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# OpenRouter configuration
OPENROUTER_MODEL=google/gemini-2.5-flash

# Alexa configuration
# Set to 'true' to bypass cryptographic signature verification during local testing/mocking
SKIP_ALEXA_VERIFICATION=false
